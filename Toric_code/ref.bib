	doi = {10.1038/s41467-021-22274-1},
	id = {Bonilla Ataides2021},
	isbn = {2041-1723},
	journal = {Nature Communications},
	number = {1},
	pages = {2172},
	title = {The XZZX surface code},
	url = {https://doi.org/10.1038/s41467-021-22274-1},
